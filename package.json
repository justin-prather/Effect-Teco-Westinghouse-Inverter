{
  "name": "effect-teco-westinghouse-inverter",
  "version": "1.0.0",
  "description": "",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "test": "bun test src/schemas src/parameters",
    "test:coverage": "bun test --coverage src/schemas src/parameters",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf ./dist && bun build ./index.ts --outdir ./dist --target node --external effect --external effect-modbus-rs --external modbus-rs && tsc --noEmit false --emitDeclarationOnly --outDir ./dist --rootDir ."
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.3",
    "@effect/platform-bun": "^0.90.0",
    "@types/bun": "latest",
    "fallow": "^2.104.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "effect": "^3.21.4",
    "effect-modbus-rs": "github:justin-prather/Effect-modbus-rs"
  }
}
